{
  "manifest_version": 3,
  "name": "知识库保存助手",
  "version": "1.0.0",
  "description": "将网页一键保存到个人知识库",
  "permissions": ["activeTab", "scripting", "nativeMessaging", "contextMenus"],
  "host_permissions": [
    "https://mmbiz.qpic.cn/*",
    "https://*.qpic.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
